# DeepSeek API Key (required)
# Get yours at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-key-here

# Server port (optional, default 3001)
PORT=3001

# Search provider: "baidu" (default, free, no key, works in China) or "bing" (needs API key)
# Bing free tier (1000/month): https://portal.azure.com → Bing Search v7
SEARCH_PROVIDER=baidu
BING_API_KEY=
